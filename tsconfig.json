{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@mcp/*": ["mcp/*"]
    },
    "lib": ["ES2022"],
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "orchestrator/**/*.ts",
    "prompt-engine/**/*.ts",
    "mcp/**/*.ts",
    "memory/**/*.ts",
    "tests/**/*.ts"
  ]
}

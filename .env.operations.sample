# Operations profile (observability-oriented)
# Usage (PowerShell):
#   Copy-Item .env.operations.sample .env

SF_AI_DOTENV_DISABLE=0

# Use absolute paths when sharing one MCP server across multiple repositories.
SF_AI_OUTPUTS_DIR=D:/sf-ai-data/outputs
SF_AI_HISTORY_SQLITE=true
SF_AI_STATE_DB_PATH=D:/sf-ai-data/outputs/state.sqlite
SF_AI_OUTPUTS_BACKUP_DIR=D:/sf-ai-data/outputs/backups
SF_AI_OUTPUTS_BACKUP_KEEP=7

SF_AI_MEMORY_FILE=D:/sf-ai-data/outputs/memory.jsonl
SF_AI_VECTOR_STORE_FILE=D:/sf-ai-data/outputs/vector-store.jsonl
SF_AI_TRACE_FILE=D:/sf-ai-data/outputs/events/trace-log.jsonl
SF_AI_METRICS_FILE=D:/sf-ai-data/outputs/events/metrics-samples.jsonl

LOG_LEVEL=info
SF_AI_DEBUG_VERBOSE_PROMPT=false
SF_AI_LOCALE=ja

AI_LOW_RELEVANCE_THRESHOLD=6

SF_AI_AUTO_MEMORY=false
SF_AI_PROGRESS_BANNER=true

AI_PROMPT_CACHE_MAX_ENTRIES=200
AI_PROMPT_CACHE_TTL_SECONDS=600
PROMPT_CACHE_FILE=D:/sf-ai-data/outputs/prompt-cache.jsonl

AI_AGENT_TRUST_SCORING_ENABLED=true
AI_AGENT_TRUST_THRESHOLD=0.55

SF_AI_AUTO_APPLY=false
SF_AI_AUTO_APPLY_MIN_SCORE=70
SF_AI_AUTO_APPLY_MAX_PER_DAY=5
SF_AI_AUTO_APPLY_MAX_DELETIONS=3

OLLAMA_REQUIRED=false
OLLAMA_BASE_URL=http://localhost:11434
AI_LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_INIT_MODELS=qwen2.5:3b nomic-embed-text:latest

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=salesforce-ai-company
PROMETHEUS_METRICS_PORT=9464

SF_AI_BENCHMARK_TRACE_LIMIT=500
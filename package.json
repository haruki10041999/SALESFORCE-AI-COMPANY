{
  "name": "salesforce-ai-company",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "help": "node scripts/help.js",
    "init": "node scripts/init-config.js",
    "doctor": "node scripts/doctor.js",
    "build": "tsc -p tsconfig.json",
    "mcp:dev": "tsx mcp/server.ts",
    "mcp:start": "node dist/mcp/server.js",
    "test": "node scripts/test.mjs",
    "ci": "npm run typecheck && npm test && npm run audit:deps",
    "sf": "node scripts/sfdx-wrapper.js",
    "scaffold": "tsx scripts/scaffold.ts",
    "clean:outputs": "tsx scripts/cleanup-outputs.ts",
    "mask:logs": "tsx scripts/mask-existing-logs.ts",
    "archive:history": "tsx scripts/archive-history.ts",
    "report:metrics": "node scripts/metrics-report.js",
    "lint:outputs": "tsx scripts/lint-outputs.ts",
    "docs:build": "tsx scripts/generate-tools-doc.ts",
    "ai": "tsx scripts/ai.ts",
    "typecheck": "tsc --noEmit",
    "audit:deps": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@apexdevtools/apex-parser": "^4.4.1",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/sdk-node": "^0.57.2",
    "fast-xml-parser": "^5.0.0",
    "js-tiktoken": "^1.0.16",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "fast-check": "^4.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}

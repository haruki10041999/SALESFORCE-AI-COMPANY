{
  "name": "salesforce-ai-company",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ai": "tsx scripts/ai.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm test && npm run audit:deps",
    "mcp:dev": "tsx mcp/server.ts",
    "mcp:start": "node dist/mcp/server.js",
    "test": "node --test --import tsx --import ./tests/_setup.ts tests/**/*.test.ts",
    "audit:deps": "npm audit --audit-level=moderate",
    "metrics:report": "node scripts/metrics-report.js",
    "metrics:snapshot": "node scripts/metrics-snapshot.js",
    "benchmark:run": "tsx scripts/benchmark-suite.ts",
    "tail:progress": "tsx scripts/tail-progress.ts",
    "metrics:seed": "node scripts/seed-metrics.js",
    "metrics:dashboard": "node scripts/metrics-dashboard.js",
    "history:archive": "tsx scripts/archive-history.ts",
    "test:matrix": "tsx scripts/test-matrix.ts",
    "test:selective": "tsx scripts/run-selective-tests.ts",
    "logs:remask": "tsx scripts/mask-existing-logs.ts",
    "outputs:cleanup": "tsx scripts/cleanup-outputs.ts",
    "outputs:version": "tsx scripts/outputs-version.ts",
    "scaffold": "tsx scripts/scaffold.ts",
    "docs:manifest": "tsx scripts/generate-tool-manifest.ts",
    "tools:compat": "tsx scripts/check-tool-compatibility.ts",
    "init": "node scripts/init-config.js",
    "doctor": "node scripts/doctor.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "fast-check": "^4.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
